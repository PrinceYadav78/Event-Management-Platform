# Keep the image small and never bake secrets into it
.git/
.gitignore
.venv/
venv/
env/
__pycache__/
*.pyc
*.pyo
# local SQLite mirror (rebuilt from Firestore at runtime)
*.db
*.sqlite3
# secrets — provided to Cloud Run via env var / Secret Manager, NOT the image
.env
*firebase-adminsdk*.json
# Windows-only build tool, not needed in the linux container
*.exe
# editor / docs / misc
.vscode/
.idea/
*.md
render.yaml
Dockerfile
.dockerignore
.gcloudignore
