rules_version = '2';

// Security rules for the named database: ai-studio-5c89681c-cdd0-4be4-8754-2183d8282c52
//
// This database is accessed ONLY by the FastAPI backend through the Firebase
// Admin SDK (service account). The Admin SDK has full privileges and BYPASSES
// these rules entirely — so the safest possible rule is to deny every direct
// client/browser request. No password hashes or student data are ever exposed
// to the public.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
